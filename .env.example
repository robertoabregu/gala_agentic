BENEFITS_DISTANCE_TO_KM=10
BENEFITS_MAX_RESULTS=5
BENEFITS_DETAIL_MAX_CANDIDATES=5
BENEFITS_DETAIL_EXPANSION_BATCH=3
BENEFITS_MIN_PROMO_RESULTS=3
BENEFITS_REQUEST_TIMEOUT=8
BENEFITS_NEARBY_CACHE_TTL_SECONDS=180
BENEFITS_DETAIL_CACHE_TTL_SECONDS=600
BENEFITS_LOCATION_CACHE_ROUND_DECIMALS=3

# WhatsApp / Twilio
