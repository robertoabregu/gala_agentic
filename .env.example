# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG
MIN_CHUNK_SIZE=500
MAX_CHUNK_SIZE=800
RAG_SCORE_THRESHOLD=0.5

# Langfuse opcional
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Scripts de enriquecimiento opcionales
OPENAI_MODEL_ENRICH=gpt-4o-mini
ENRICH_INPUT_PATH=data/documents.json
ENRICH_OUTPUT_PATH=data/documents_enriched.json
OPENAI_MODEL_CHITCHAT=gpt-4o-mini
